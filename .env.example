# Copy to .env and fill in your API tokens (never commit .env).
# CI/CD uses GitHub repository secrets instead of this file.

TINKOFF_TOKEN=
TWELVEDATA_TOKEN=

# Optional: Bybit API key (public kline endpoint works without a key)
# BYBIT_TOKEN=

# Optional: PostgreSQL connection (defaults to sqlite:///data/backtest.db)
# DATABASE_URL=

# Optional: default data source for examples (tbank | twelvedata | bybit)
# DATA_SOURCE=tbank
