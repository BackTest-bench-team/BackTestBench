TINKOFF_TOKEN
TWELVEDATA_TOKEN

# Which data API to use by default in examples.tbank_adapter_usage.
# Supported: tbank | twelvedata | bybit. Can be overridden per-call via source=...
# DATA_SOURCE=tbank

# Optional: PostgreSQL connection (defaults to sqlite:///data/backtest.db)
# DATABASE_URL=postgresql://user:pass@localhost:5432/backtest